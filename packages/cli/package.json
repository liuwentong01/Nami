{
  "name": "@nami/cli",
  "version": "0.1.0",
  "description": "Nami 框架 CLI 命令行工具",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "nami": "./bin/nami.js"
  },
  "files": ["dist", "bin"],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@nami/shared": "workspace:*",
    "@nami/core": "workspace:*",
    "@nami/webpack": "workspace:*",
    "@nami/server": "workspace:*",
    "commander": "^12.0.0",
    "chalk": "^4.1.2",
    "ora": "^5.4.1",
    "detect-port": "^1.5.0",
    "esbuild": "^0.20.0"
  },
  "devDependencies": {
    "@types/detect-port": "^1.3.0"
  },
  "keywords": ["nami", "cli"],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
